{
  "theme_label": "Shop",
  "theme_description": "Ein modernes Theme für Storefronts und Produkt-Help-Center: Handbücher, Video-Tutorials, FAQs und Downloads.",
  "settings_schema": {
    "recommendations": {
      "color_schemas": {
        "baklib_default": {
          "name": "Baklib Türkis"
        },
        "fashion": {
          "name": "Mode"
        },
        "old_school": {
          "name": "Vintage"
        },
        "shop_minimal": {
          "name": "Shop Minimal"
        },
        "ocean_trust": {
          "name": "Ocean Trust"
        },
        "cross_border_store": {
          "name": "Grenzüberschreitender Shop"
        }
      },
      "initial_pages": {
        "default": {
          "name": "Shop eins",
          "pages": {
            "products": "Produkte",
            "downloads": "Downloads",
            "videos": "Videos",
            "faqs": "FAQs"
          }
        }
      }
    },
    "theme_defaults": {
      "name": "Theme-Standardwerte",
      "settings": {
        "logo_url": {
          "label": "Site-Logo",
          "info": "Wird in der Kopfzeilen-Navigation angezeigt."
        },
        "avatar_url": {
          "label": "Standard-Avatar",
          "info": "Wird im KI-Suchpanel angezeigt."
        },
        "request_form_url": {
          "label": "URL des Anfrageformulars",
          "info": "Nur HTTPS. Wenn gesetzt, erscheint unter dem Feedback ein Link „Anfrage senden“."
        },
        "robot_name": {
          "label": "Name des KI-Assistenten",
          "info": "Wird in der Kopfzeile des KI-Suchpanels angezeigt."
        },
        "ai_search_completed_text": {
          "label": "KI-Abschlusstext",
          "info": "Wird angezeigt, nachdem die KI-Suche eine Antwort geliefert hat."
        }
      }
    },
    "home_faqs": {
      "name": "Startseite — FAQs-Bereich",
      "settings": {
        "section_faqs_on": {
          "label": "FAQs-Bereich anzeigen",
          "info": "Wenn aktiviert, wird der FAQs-Bereich auf der Startseite angezeigt."
        },
        "section_faqs_title": {
          "label": "Bereichstitel"
        },
        "section_faqs_menu": {
          "label": "FAQs-Navigation",
          "info": "Format: name[slug{description — eine Spalte pro Zeile."
        }
      }
    },
    "home_products": {
      "name": "Startseite — Produktbereich",
      "settings": {
        "section_products_on": {
          "label": "Produktbereich anzeigen",
          "info": "Wenn aktiviert, wird der Produktbereich auf der Startseite angezeigt."
        },
        "section_product_type": {
          "label": "Produkte nach Kategorie gruppieren",
          "info": "Wenn aktiviert, werden Produkte nach Kategorie gruppiert; sonst alle Produkte."
        },
        "section_product_title": {
          "label": "Bereichstitel"
        },
        "product_categories": {
          "label": "Produktkategorien",
          "info": "Format: Kategorie A|Kategorie B|Kategorie C. Passende Tags in der Tag-Verwaltung anlegen."
        }
      }
    },
    "home_topics": {
      "name": "Startseite — Themenbereich",
      "settings": {
        "section_topics_on": {
          "label": "Themenbereich anzeigen",
