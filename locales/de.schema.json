        "section_topic_title": {
          "label": "Bereichstitel"
        },
        "topics_menu": {
          "label": "Themen-Navigation der Startseite",
          "info": "Format: name[slug[description — eine Spalte pro Zeile."
        }
      }
    },
    "home_downloads": {
      "name": "Startseite — Download-Bereich",
      "settings": {
        "section_downloads_on": {
          "label": "Download-Bereich anzeigen",
