        "contact_name": {
          "label": "Beschriftung des Kontaktformulars"
        }
      }
    },
    "header_footer": {
      "name": "Kopf- und Fußzeilenmenüs",
      "settings": {
        "header_menu": {
          "label": "Kopfzeilen-Navigation",
          "info": "Format: menu_name[slug]{sub_menu[slug|sub_menu[slug — eine Spalte pro Zeile."
        },
        "footer_menu": {
          "label": "Fußzeilenmenü",
          "info": "Format: menu_name[slug]{sub_menu[slug|sub_menu[slug — eine Spalte pro Zeile."
        },
        "company_info": {
          "label": "Fußzeilen-Copyright"
        },
        "friend_links": {
          "label": "Social-Media-Links in der Fußzeile",
          "info": "Format: <a href=''>svg icon</a>. Icon-Referenz: https://www.bootstrapmb.com/icon"
        },
        "font_html": {
          "label": "Benutzerdefinierte Schriftarten",
          "info": "Schriftfamilie und Pfade wie im Standardwert ersetzen. Schriften mit der Klasse .font-custom anwenden."
        },
        "head_html": {
          "label": "HTML innerhalb von <head>"
        }
      }
    }
  },
