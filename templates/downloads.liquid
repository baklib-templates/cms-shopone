{% assign pages = page.children_in_list %}
{% for item in pages %}
    {% if item.template_name == 'downloads' %}
        {% assign type =  'channel' %}
        {% break %}
    {% endif %}
{% endfor %}

{% # Breadcrumb %}
<section class="py-2 bg-secondary/10">
    <div class="max-w-6xl mx-auto px-4">
        <div class="mb-4">
            {% render 'breadcrumb', breadcrumb: page.breadcrumb  %}
        </div>
    </div>
    <div class="mx-auto max-w-2xl md:flex flex-col items-center justify-center py-4">
        <h2 class="font-semibold tracking-tight base-content md:text-3xl text-2xl flex items-center">
            {{ page.settings.title }}</h2>
        <p class="mt-2 ml-2 text-sm base-content/80">{{ page.settings.description }}</p>
    </div>
</section>

<section class=" py-6 sm:py-12">
    <div class="mx-auto max-w-6xl px-4">
        {% if type == 'channel' %}
            <section>
                {% for item in pages %}
                    {% if item.template_name == 'downloads' %}
                        {% render 'content_downloads', page: item, show_header: true %}
                    {% else %}
                        {% render 'content_post', page: item %}
                    {% endif %}
                {% endfor %}
            </section>
        {% else %}
            {% paginate_tag pages, per: 12 %}
                <div class="grid grid-cols-1 gap-4 md:gap-8 sm:grid-cols-3 mt-4">
                    {% for item2 in pages %}
                        {% render 'content_card', item: item2 %}
                    {% endfor %}
                </div>
                <div class="w-full text-right block mt-12">
                    {% render 'paginate', paginate: paginate %}
                </div>
            {% endpaginate_tag %}
        {% endif %}
    </div>
</section>

{% schema %}
  {
    "name": "t:schema.templates.downloads.name",
    "description": "t:schema.templates.downloads.description",
    "thumb_url": "images/theme/${lang}/downloads.webp",
    "sub_page_templates": ["post","downloads"],
    "settings": [
      {
        "id": "title",
        "type": "text",
        "label": "t:schema.templates.downloads.settings.title.label"
      },
      {
        "id": "description",
        "type": "textarea",
        "label": "t:schema.templates.downloads.settings.description.label"
      }
    ]
  }
{% endschema%}
