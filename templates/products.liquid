

<section class="py-2">
    <div class="max-w-6xl mx-auto px-4">
        <div class="mb-4">
            {% render 'breadcrumb', breadcrumb: page.breadcrumb  %}
        </div>
    </div>
</section>

<!-- 产品列表 -->
<section class="bg-white py-6 sm:py-12">
    <div class="mx-auto max-w-6xl px-4">
        <div class="mx-auto max-w-2xl md:flex flex-col items-center justify-center">
            <h2 class="font-semibold tracking-tight base-content md:text-3xl text-2xl flex items-center">
                {{ page.settings.title }}</h2>
            <p class="mt-2 ml-2 text-sm base-content/80">{{ page.settings.description }}</p>
        </div>

        <!-- Cards Container -->
        {% if site.settings.section_product_type == true %}
            {% render 'content_products', tag: tag %}
        {% else %}
            {% render 'content_products_all' %}
        {% endif %}
    </div>
</section>

<!-- Support 列表 -->
{% if site.settings.section_contact_on %}
    {% render 'content_contacts', page: page %}
{% endif %}

{% schema %}
    {
    "name": "t:schema.templates.products.name",
    "description": "t:schema.templates.products.description",
    "thumb_url": "images/theme/${lang}/products.webp",
    "sub_page_templates": ["product"],
    "settings": [
        {
            "id": "title",
            "type": "text",
            "label": "t:schema.templates.products.settings.title.label"
        },
        {
            "id": "description",
            "type": "textarea",
            "label": "t:schema.templates.products.settings.description.label"
        }
    ]
    }
{% endschema%}
