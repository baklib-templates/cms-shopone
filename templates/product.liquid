{%  assign pages = page.children_in_nav_menu %}
{% for item in page.children_in_nav_menu | limit: 1 %}
  {%  assign first_page =  item %}
{% endfor %}

<!-- Header -->
<section class="relative max-w-6xl mx-auto px-4">
    <!-- Article hero thumb -->
    <header class="py-0">
      <img src="{{ page.settings.hero_image_url | default: page.settings.thumb_image_url }}" alt="{{ page.settings.title }}" class="w-full object-cover">
    </header>

    <!-- Article header -->
    <div class="relative max-w-6xl mx-auto my-4">
      <div class="mb-4">
        {% render 'breadcrumb', breadcrumb: page.breadcrumb  %}
      </div>
      <div class="flex justify-between">
        <div class="">
          <h1 class="text-3xl md:text-5xl font-bold text-gray-900">{{ page.settings.title }}</h1>
          <p class="mt-2 text-sm text-gray-500">{{ page.settings.description }}</p>
        </div>
        <div class="">
          {% if page.settings.external_url %}
            <div class="flex items-center justify-end">
              <a href="{{ page.settings.external_url | default: '#' }}" target="_blank" rel="noopener noreferrer" class="text-white bg-secondary hover:bg-primary focus:outline-none focus:ring-4 focus:ring-primary-300 font-medium rounded-full text-sm px-5 py-2.5 text-center me-2 mb-2 dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">Shop Now</a>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
</section>

<!-- Content -->
<section class="relative max-w-6xl mx-auto px-4">
  {% render 'content', page: page %}
</section>

<section x-data="{ activeTab: '{{ first_page.id }}' }" class="relative max-w-6xl mx-auto px-4 my-4 md:my-8">
    <!-- Article Navigation -->
    <div class="bg-gray-100 rounded-md px-4 py-0 my-4">
      <div class="max-w-3xl mx-auto">
        <nav class="flex justify-between w-full overflow-x-auto" aria-label="Tabs">
          <!-- Current: "bg-gray-200 text-gray-800", Default: "text-gray-600 hover:text-gray-800" -->
          {% for item in pages %}
            <a href="#" data-product="{{ item.id }}" @click.prevent="activeTab = '{{ item.id }}'" :class="{ 'bg-gray-800 text-white': activeTab === '{{ item.id }}' }"  class="rounded-md px-3 py-2 text-sm md:text-lg font-semibold max-w-24 md:max-w-64" aria-current="page">
              {{ item.link_text}}
            </a>
          {% endfor %}
        </nav>
      </div>
    </div>

    <!-- Article Content -->
    {% for item in pages %}
      <div x-show="activeTab === '{{ item.id }}'" x-data="{ activeTab2: '{{ item.id }}' }" class="relative px-4">
        <div class="flex flex-col items-start">
          
          {% if item.slug == 'faq' %}
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
                {% for item in item.children_in_list  %}
                    {%  assign sub_items_count= item.children_in_list | size %}
                    {% if sub_items_count > 0 %}
                        <div>
                            <h3 class="text-xl mb-2 font-semibold border-b border-primary">{{ item.settings.title  }}</h3>
                            {% assign sub_items = item.children_in_list | limit: 12  %}
                            {% for item2 in sub_items %}
                                {% render 'content_faq', item: item2 %}
                            {% endfor %}
                            {% if sub_items_count > 12 %}
                                <div class="text-center mt-4">
                                    <a href="{{ item.url }}" class="btn btn-primary">Learn more</a>
                                </div>
                            {% endif %}
                        </div>
                    {% else %}
                        {% render 'content_faq', item: item %}
                    {% endif %}
                {% endfor %}
              </div>
            {% else %}

              <article x-show="activeTab2 === '{{ item.id }}'" class="flex-1">
                {% render 'content', page: item %}
              </article>
              {% for sub_item in item.children_in_list %}
                <article x-show="activeTab2 === '{{ sub_item.id }}'" class="flex-1">
                  {% render 'content', page: sub_item %}
                </article>
              {% endfor %}
          {% endif %}

        </div>
      </div>
    {% endfor %}
    <!-- Feedback -->
    <div class="max-w-2xl mx-auto mt-8">
      {% render "feedback_form", page: page %}
    </div>
</section>

<!-- Support 列表 -->
{% render 'need_help', page: page %}

<!--/ article-->
{% schema %}
  {
    "name": "详情页-产品/项目页面",
    "description": "产品/项目/案例详情页面模板",
    "thumb_url": "images/theme/product.webp",
    "sub_page_templates": ["faqs","videos","news"],
    "settings": [
      {
        "id": "title",
        "type": "text",
        "label": "标题"
      },
      {
        "id": "description",
        "type": "textarea",
        "label": "摘要"
      },
      {
        "id": "content",
        "type": "richtext",
        "label": "内容"
      },
      {
        "id": "thumb_image_url",
        "type": "image_picker",
        "ratio": "4:3",
        "width": 300,
        "label": "封面图"
      },
      {
        "id": "hero_image_url",
        "type": "image_picker",
        "ratio": "6:2",
        "width": 400,
        "label": "详情页封面图"
      },
      {
        "id": "tags",
        "type": "tag_picker",
        "multiple": true,
        "label": "标签"
      },
      {
          "id": "external_url",
          "type": "text",
          "placeholder": "https://",
          "default": "#",
          "label": "外部链接(Learn More)",
          "info": "如果添加了外链，点击会跳转到该链接，以下的内容就可以补充"
      }
    ]
  }
{% endschema%}