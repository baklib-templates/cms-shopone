{% assign chat_messages = site.chat_messages | order_by: '-created_at' | limit: 10 %}
{% assign avatar = site.default.avatar_url %}
{% unless avatar %}
  {% assign avatar = 'images/avatar.svg' | asset_url %}
{% endunless %}
{% assign extends_size = search.extends | size %}
{% assign items_size = search.pages | size %}
{% assign total_size = extends_size | plus: items_size %}
{% assign ai_search_thinking_text = 'templates.search.ai.thinking' | t %}
{% assign ai_search_canceled_text = 'templates.search.ai.canceled' | t %}
{% assign ai_search_completed_default = 'templates.search.ai.completed' | t %}
{% assign ai_assistant_default_name = 'templates.search.ai.assistant_name' | t %}

<div class="relative bg-base-100">
  <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-64 bg-gradient-to-b from-primary/10 to-transparent"></div>

  <main id="content" class="page-container py-8 md:py-10 print:py-0">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight text-base-content md:text-4xl">{{ 'templates.search.title' | t }}</h1>
      <p class="mt-2 text-sm text-base-content/65 md:text-base">{{ 'templates.search.subtitle' | t }}</p>
    </div>

    <div class="mt-6 flex flex-col gap-6 lg:flex-row">
      <div class="order-2 min-w-0 flex-1 lg:order-1">
        <div class="overflow-hidden rounded-box border border-base-300 bg-base-100">
          <turbo-frame id="frame--search-results" class="block">
            {% if total_size > 0 %}
              {% paginate_tag search.pages, as: 'items', per: 20 %}
                <div class="p-4 md:p-5">
                  <div class="mb-4 text-sm text-base-content/65" role="heading" aria-level="2">{{ 'templates.search.results.count_label' | t: count: total_size }}</div>
                  <div class="space-y-3">
                    {% if search.page_number == 1 and extends_size > 0 %}
                      {% for link in search.extends %}
                        <a href="{{ link.url }}" data-turbo-frame="_top" class="group block rounded-box border border-base-300 bg-base-100 p-4 transition hover:border-primary/40 hover:bg-base-200/35">
                          <div class="flex items-start gap-3">
                            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/15 text-xs font-medium text-primary">{{ forloop.index }}</span>
                            <div class="min-w-0 flex-1">
                              <p class="search-highlight-block font-medium text-base-content group-hover:text-primary">{{ link.link_text }}</p>
                              <p class="mt-1 line-clamp-1 text-sm text-base-content/55">{{ link.url }}</p>
                            </div>
                            <i data-lucide="chevron-right" class="mt-1 h-4 w-4 shrink-0 text-base-content/35 group-hover:text-primary"></i>
                          </div>
                        </a>
                      {% endfor %}
                    {% endif %}

                    {% for item in items %}
                      <a href="{{ item.url }}" data-turbo-frame="_top" class="group block bg-base-100 p-4 transition hover:border-primary/40 hover:bg-base-200/35">
                        <div class="flex items-start gap-3">
                          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/15 text-xs font-medium text-primary">{{ forloop.index | plus: extends_size }}</span>
                          <div class="min-w-0 flex-1">
                            <p class="search-highlight-block font-medium text-base-content group-hover:text-primary">{{ item.highlighted_search_title }}</p>
                            {% unless item.highlighted_search_content == empty %}
                              <p class="search-highlight-block mt-1 line-clamp-2 text-sm text-base-content/60">{{ item.highlighted_search_content }}</p>
                            {% endunless %}
                          </div>
                          <i data-lucide="chevron-right" class="mt-1 h-4 w-4 shrink-0 text-base-content/35 group-hover:text-primary"></i>
                        </div>
                      </a>
                    {% endfor %}
                  </div>
                  <div class="mt-6 flex justify-center border-t border-base-300 pt-4">
                    {% render 'paginate', paginate: paginate %}
                  </div>
                </div>
              {% endpaginate_tag %}
            {% else %}
              <div class="p-12 text-center text-base-content/55">
                <i data-lucide="search-x" class="mx-auto mb-4 h-12 w-12 text-base-content/30"></i>
                <p class="text-sm">{{ 'templates.search.empty.title' | t }}</p>
                <p class="mt-1 text-xs">{{ 'templates.search.empty.hint' | t }}</p>
              </div>
            {% endif %}
          </turbo-frame>
        </div>
      </div>

      <div class="order-1 w-full shrink-0 lg:order-2 lg:w-96">
        <div
          class="ai-assistant-panel lg:sticky lg:top-24"
          data-controller="ai-assistant-panel"
          data-ai-assistant-panel-expanded-class="ai-assistant-panel--expanded"
        >
          <div
            data-ai-assistant-panel-target="backdrop"
            data-action="click->ai-assistant-panel#collapse"
            class="ai-assistant-panel__backdrop"
            aria-hidden="true"
          ></div>
          <div id="js--ai-search-completion-container" data-ai-assistant-panel-target="panel" class="ai-assistant-panel__panel">
            <div
              id="js--ai-search-completion"
              data-controller="ai-search-completion"
              data-ai-search-completion-hidden-class="hidden opacity-0"
              data-ai-search-completion-messages-value='{"thinking":"{{ ai_search_thinking_text | escape_once }}","completed":"{{ site.settings.ai_search_completed_text | default: ai_search_completed_default | escape_once }}","canceled":"{{ ai_search_canceled_text | escape_once }}"}'
              data-ai-search-completion-url-value="/-/ai-search-completion"
              data-ai-search-completion-auto-submit-value="true"
            >
              <div class="ai-assistant-panel__dialog flex min-h-[420px] flex-col overflow-hidden rounded-box border border-base-300 bg-base-100">
                <div class="flex items-center gap-2 border-b border-base-300 px-4 py-3">
                  <span class="relative flex h-2.5 w-2.5 shrink-0">
                    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary/60 opacity-75"></span>
                    <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-primary"></span>
                  </span>
                  <span class="min-w-0 flex-1 truncate text-sm font-medium text-base-content">{{ site.settings.robot_name | default: ai_assistant_default_name }}</span>
                  <button
                    type="button"
                    data-ai-assistant-panel-target="expandBtn"
                    data-action="click->ai-assistant-panel#expand"
                    class="flex h-8 w-8 shrink-0 items-center justify-center rounded-box text-base-content/60 transition hover:bg-base-200 hover:text-base-content"
                    aria-label="{{ 'templates.search.ai.expand' | t }}"
                  >
                    <i data-lucide="maximize-2" class="h-4 w-4"></i>
                  </button>
                  <button
                    type="button"
                    data-ai-assistant-panel-target="collapseBtn"
                    data-action="click->ai-assistant-panel#collapse"
                    class="hidden h-8 w-8 shrink-0 items-center justify-center rounded-box text-base-content/60 transition hover:bg-base-200 hover:text-base-content"
                    aria-label="{{ 'templates.search.ai.collapse' | t }}"
                  >
                    <i data-lucide="minimize-2" class="h-4 w-4"></i>
                  </button>
                </div>

                <div data-ai-search-scroll-container class="max-h-[360px] flex-1 space-y-4 overflow-y-auto p-4">
                  {% for message in chat_messages reversed %}
                    {% if message.role == 'user' %}
                      <div class="flex items-end justify-end gap-2">
                        <div class="max-w-[85%]">
                          <div class="inline-block rounded-box rounded-br-md bg-primary px-4 py-2 text-sm text-primary-content">{{ message.content }}</div>
                          {% if current_user %}<p class="mt-1 text-right text-xs text-base-content/50">{{ current_user.name }}</p>{% endif %}
                        </div>
                        <img src="{{ current_user.image | default: avatar }}" alt="" class="h-8 w-8 shrink-0 rounded-full" />
                      </div>
                    {% else %}
                      <div class="flex items-start gap-2">
                        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-primary-content">
                          <i data-lucide="sparkles" class="h-4 w-4"></i>
                        </div>
                        <div class="min-w-0 flex-1">
                          <div class="ai-assistant-message prose prose-sm max-w-full rounded-box rounded-bl-md bg-base-200 px-4 py-2 text-sm text-base-content">{{ message.content }}</div>
                          <p class="mt-1 text-xs text-base-content/50">{{ site.settings.robot_name | default: ai_assistant_default_name }}</p>
                        </div>
                      </div>
                    {% endif %}
                  {% endfor %}
                  <div data-ai-search-completion-target="messages" class="space-y-4"></div>
                </div>

                <template data-ai-search-completion-target="userMessageTemplate">
                  <div class="flex items-end justify-end gap-2">
                    <div class="max-w-[85%]">
                      <div class="ai-user-message inline-block rounded-box rounded-br-md bg-primary px-4 py-2 text-sm text-primary-content"></div>
                      {% if current_user %}<p class="mt-1 text-right text-xs text-base-content/50">{{ current_user.name }}</p>{% endif %}
                    </div>
                    <img src="{{ current_user.image | default: avatar }}" alt="" class="h-8 w-8 shrink-0 rounded-full" />
                  </div>
                </template>

                <template data-ai-search-completion-target="assistantMessageTemplate">
                  <div class="flex items-start gap-2">
                    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-primary-content">
                      <i data-lucide="sparkles" class="h-4 w-4"></i>
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="ai-assistant-message prose prose-sm max-w-full rounded-box rounded-bl-md bg-base-200 px-4 py-2 text-sm text-base-content"></div>
                      <p class="mt-1 text-xs text-base-content/50">{{ site.settings.robot_name | default: ai_assistant_default_name }}</p>
                    </div>
                  </div>
                </template>

                <div data-ai-search-completion-target="error" class="hidden px-4 text-sm text-error"></div>

                <div id="ai-footer" class="ai-assistant-panel__footer border-t border-base-300 p-4">
                  <div class="flex gap-2">
                    <textarea
                      id="js--ai-chat-input"
                      data-ai-search-completion-target="input"
                      autocomplete="off"
                      class="flex-1 resize-none rounded-box border border-base-300 bg-base-100 px-4 py-2.5 text-sm text-base-content placeholder:text-base-content/45 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                      placeholder="{{ 'templates.search.ai.input_placeholder' | t }}"
                      rows="1"
                    ></textarea>
                    <button
                      id="js--ai-chat-send"
                      data-ai-search-completion-target="send"
                      type="button"
                      class="flex h-10 w-10 shrink-0 items-center justify-center rounded-box bg-primary text-primary-content transition hover:opacity-90"
                    >
                      <i data-lucide="send" class="h-5 w-5"></i>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    (function () {
      setTimeout(function () {
        var completion = document.getElementById("js--ai-search-completion");
        if (completion) completion.dataset.aiSearchCompletionMessageValue = "{{ search.keywords | escape_once }}";
      }, 500);
    })();
  </script>
  <script>
    document.addEventListener("turbo:load", function () {
      var searchInput = document.getElementById("js--search-input");
      var chatInput = document.getElementById("js--ai-chat-input");
      var sendBtn = document.getElementById("js--ai-chat-send");
      if (!chatInput || !sendBtn) return;

      function syncAndSubmit() {
        if (searchInput && chatInput.value) {
          searchInput.value = chatInput.value;
          var form = searchInput.form;
          if (form) form.requestSubmit();
        }
      }

      chatInput.addEventListener("keydown", function (e) {
        if (e.key === "Enter" && !e.shiftKey) {
          e.preventDefault();
          syncAndSubmit();
        }
      });

      sendBtn.addEventListener("click", syncAndSubmit);
    });
  </script>
</div>
