{% comment %} Article from: https://cruip.com/how-to-build-a-modal-video-with-html-tailwind-css-and-alpine-js {% endcomment %}
{% assign picked_video = page.settings.video_url %}
{% assign local_src = "" %}

{% if picked_video != blank %}
  {% if picked_video.url != blank %}
    {% assign local_src = picked_video.url %}
  {% elsif picked_video contains 'http' or picked_video contains '/' %}
    {% assign local_src = picked_video %}
  {% endif %}
{% endif %}

{% assign youtube_id = page.settings.youtube_id | strip %}
{%- if video_type == "1" -%}
  {%  assign thumb_class = "aspect-[9/16] mx-auto max-h-screen rounded-xl bg-base-200 object-cover" %}
{%- else -%}
  {%  assign thumb_class = "aspect-[16/9] mx-auto max-h-screen rounded-xl bg-base-200 object-cover" %}
{%- endif -%}

{% if local_src != blank %}
  {% comment %} video_picker: prefer local video, try to use preview cover as thumb {% endcomment %}
  {% assign local_thumb = "" %}
  {% if picked_video.previewable? %}
    {% assign local_thumb = picked_video.preview.cover | default: picked_video.preview.thumb %}
  {% endif %}

  <div class="[&_[x-cloak]]:hidden" x-data="{ modalOpen: false }">
    <button
        class="relative flex justify-center items-center focus:outline-none focus-visible:ring focus-visible:ring-primary rounded-3xl group"
        @click="modalOpen = true"
        aria-controls="modal"
        aria-label="Watch the video"
    >
      {% if local_thumb != blank %}
        <img src="{{ local_thumb }}" alt="{{ page.link_text }}" class="{{ thumb_class }}">
      {% else %}
        <div class="{{ thumb_class }} bg-base-200 flex items-center justify-center" aria-hidden="true"></div>
      {% endif %}
        <span class="absolute pointer-events-none grid place-items-center transition-transform duration-300 ease-in-out group-hover:scale-110">
          <span class="h-16 w-16 rounded-full bg-base-100/80 grid place-items-center">
            <i data-lucide="circle-play" class="h-10 w-10 text-primary drop-shadow"></i>
          </span>
        </span>
    </button>

    <div
        class="fixed inset-0 z-[99999] bg-primary bg-opacity-50 transition-opacity"
        x-show="modalOpen"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-out duration-100"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        aria-hidden="true"
        x-cloak
    ></div>

    <div
        id="modal"
        class="fixed inset-0 z-[99999] flex p-6"
        role="dialog"
        aria-modal="true"
        x-show="modalOpen"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 scale-75"
        x-transition:enter-end="opacity-100 scale-100"
        x-transition:leave="transition ease-out duration-200"
        x-transition:leave-start="opacity-100 scale-100"
        x-transition:leave-end="opacity-0 scale-75"
        x-cloak
    >
        <div class="max-w-6xl mx-auto flex items-center">
            <div
                class="max-h-full bg-primary rounded-xl overflow-hidden"
                @click.outside="modalOpen = false"
                @keydown.escape.window="modalOpen = false"
            >
                <div class="aspect-[16/9] mx-auto max-h-screen flex items-center justify-center bg-black p-2">
                  <video class="max-h-[85vh] w-full max-w-full" controls playsinline preload="metadata" src="{{ local_src }}">
                  </video>
                </div>
            </div>
        </div>
    </div>
  </div>

{% elsif youtube_id != blank %}
  {% assign youtube_thumb_url = 'http://img.youtube.com/vi/' | append: youtube_id | append: '/0.jpg' %}
  {% assign youtube_embed_url = 'https://www.youtube.com/embed/' | append: youtube_id %}

  <div class="[&_[x-cloak]]:hidden" x-data="{ modalOpen: false }">

    <!-- 1. Video thumbnail -->
    <button
        class="relative flex justify-center items-center focus:outline-none focus-visible:ring focus-visible:ring-primary rounded-3xl group"
        @click="modalOpen = true"
        aria-controls="modal"
        aria-label="Watch the video"
    >
      <img src="{{ youtube_thumb_url }}" alt="{{ page.link_text }}" class="{{ thumb_class }}">
        <span class="absolute pointer-events-none grid place-items-center transition-transform duration-300 ease-in-out group-hover:scale-110">
          <span class="h-16 w-16 rounded-full bg-base-100/80 grid place-items-center">
            <i data-lucide="circle-play" class="h-10 w-10 text-primary drop-shadow"></i>
          </span>
        </span>
    </button>

    <div
        class="fixed inset-0 z-[99999] bg-primary bg-opacity-50 transition-opacity"
        x-show="modalOpen"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-out duration-100"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        aria-hidden="true"
        x-cloak
    ></div>

    <div
        id="modal"
        class="fixed inset-0 z-[99999] flex p-6"
        role="dialog"
        aria-modal="true"
        x-show="modalOpen"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 scale-75"
        x-transition:enter-end="opacity-100 scale-100"
        x-transition:leave="transition ease-out duration-200"
        x-transition:leave-start="opacity-100 scale-100"
        x-transition:leave-end="opacity-0 scale-75"
        x-cloak
    >
        <div class="max-w-6xl mx-auto flex items-center">
            <div
                class="max-h-full bg-primary rounded-xl overflow-hidden"
                @click.outside="modalOpen = false"
                @keydown.escape.window="modalOpen = false"
            >
              {% if page.settings.youtube_id != blank %}
                <div class="aspect-[16/9] mx-auto max-h-screen">
                  <iframe class="w-[1200px] h-[600px] max-w-full" src="{{ youtube_embed_url }}" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
                </div>
              {% endif %}
            </div>
        </div>
    </div>

  </div>
{% else %}
  <div class="{{ thumb_class }} flex items-center justify-center">
    <div class="text-base-content/60 text-sm flex items-center gap-2">
      <i data-lucide="video-off" class="h-4 w-4"></i>
      <span>Video not available</span>
    </div>
  </div>
{% endif %}
