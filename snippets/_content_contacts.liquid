<section class="bg-base-100 py-6 sm:py-12">
    <div class="mx-auto max-w-6xl px-4">
        <div class="mx-auto max-w-2xl md:flex flex-col items-center justify-center">
            <h2 class="font-semibold tracking-tight text-base-content md:text-3xl text-2xl flex items-center">
                {{ site.settings.section_contact_title}}</h2>
            <p class="mt-2 ml-2 text-sm text-base-content/60"></p>
        </div>

        <!-- Cards Container -->
        <section class="my-4">
            <div role="list" class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-4">
                <a href="mailto:{{ site.settings.email | default: '#' }}" class="col-span-1 flex flex-col divide-y divide-base-300 rounded-box bg-base-200 hover:bg-secondary/10 hover:no-underline text-center border border-base-300">
                    <div class="flex flex-1 flex-col p-8">
                        <div class="flex-shrink-0 group block">
                            <i data-lucide="mail" class="mx-auto h-10 w-10 shrink-0 text-primary"></i>
                        </div>
                        <h3 class="mt-6 text-lg font-medium text-base-content">Email</h3>
                        <p class="text-base-content/60 text-sm">{{ site.settings.email | default: '#' }}</p>
                    </div>
                </a>
                <a href="tel:{{ site.settings.phone | default: '#' }}"  class="col-span-1 flex flex-col divide-y divide-base-300 rounded-box bg-base-200 hover:bg-secondary/10 hover:no-underline text-center border border-base-300">
                    <div class="flex flex-1 flex-col p-8">
                        <div class="flex-shrink-0 group block">
                            <i data-lucide="phone" class="mx-auto h-10 w-10 shrink-0 text-primary"></i>
                        </div>
                        <h3 class="mt-6 text-lg font-medium text-base-content">Call Us</h3>
                        <p class="text-base-content/60 text-sm">{{ site.settings.phone_name}} </p>
                    </div>
                </a>
                <a href="{{ site.settings.chat_url | default: '#'}}" class="col-span-1 flex flex-col divide-y divide-base-300 rounded-box bg-base-200 hover:bg-secondary/10 hover:no-underline text-center border border-base-300">
                    <div class="flex flex-1 flex-col p-8">
                        <div class="flex-shrink-0 group block">
                            <i data-lucide="message-circle" class="mx-auto h-10 w-10 shrink-0 text-primary"></i>
                        </div>
                        <h3 class="mt-6 text-lg font-medium text-base-content">Chat</h3>
                        <p class="text-base-content/60 text-sm">{{ site.settings.chat_name }}</p>
                    </div>
                </a>
                <a href="{{ site.settings.contact_url | default: '#'}}" class="col-span-1 flex flex-col divide-y divide-base-300 rounded-box bg-base-200 hover:bg-secondary/10 hover:no-underline text-center border border-base-300">
                    <div class="flex flex-1 flex-col p-8">
                        <div class="flex-shrink-0 group block">
                            <i data-lucide="square-pen" class="mx-auto h-10 w-10 shrink-0 text-primary"></i>
                        </div>
                        <h3 class="mt-6 text-lg font-medium text-base-content">Contact Form</h3>
                        <p class="text-base-content/60 text-sm">{{ site.settings.contact_name }}</p>
                    </div>
                </a>
            </div>
        </section>
    </div>
</section>