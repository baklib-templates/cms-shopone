{% comment %}
  Nested sections: sub-category title + download cards (product tab / downloads channel layout).
  Flat list: card grid with optional pagination.
  pages: defaults to page.children_in_list; show_header: subsection title on downloads.liquid channel pages.
{% endcomment %}

{% unless pages %}
  {% assign pages = page.children_in_list %}
{% endunless %}

{% assign has_nested_sections = false %}
{% for item in pages %}
  {% assign sub_items_count = item.children_in_list | size %}
  {% if sub_items_count > 0 %}
    {% assign has_nested_sections = true %}
  {% endif %}
{% endfor %}

{% if show_header %}
  <div class="mb-5 flex justify-between border-b border-base-300 text-sm">
    <h3 class="pb-2 text-xl font-semibold text-base-content">{{ page.settings.title | default: page.link_text }}</h3>
    <a href="{{ page.path }}" class="text-primary hover:underline">{{ 'generic.view_all' | t }}</a>
  </div>
{% endif %}

{% if has_nested_sections %}
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8">
    {% for item in pages %}
      {% assign sub_items_count = item.children_in_list | size %}
      {% if sub_items_count > 0 %}
        <div>
          <h3 class="border-b border-primary pb-2 text-2xl font-semibold text-base-content">
            {{ item.settings.title | default: item.link_text }}
          </h3>
          <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
            {% for item2 in item.children_in_list %}
              {% render 'content_card', item: item2 %}
            {% endfor %}
          </div>
        </div>
      {% else %}
        <div>
          {% render 'content_card', item: item %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
{% else %}
  {% paginate_tag pages, per: 12 %}
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3 md:gap-8">
      {% for item in pages %}
        {% render 'content_card', item: item %}
      {% endfor %}
    </div>
    <div class="mt-12 block w-full text-right">
      {% render 'paginate', paginate: paginate %}
    </div>
  {% endpaginate_tag %}
{% endif %}
