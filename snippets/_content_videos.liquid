{% comment %}
  Nested sections: sub-category title + video cards (product tab / videos channel layout).
  Flat list: video card grid with optional pagination.
  pages: defaults to page.children_in_list; show_header: subsection title on videos.liquid channel pages.
{% endcomment %}

{% unless pages %}
  {% assign pages = page.children_in_list %}
{% endunless %}

{% assign video_type = page.settings.video_type.value | default: '0' %}

{% assign has_nested_sections = false %}
{% for item in pages %}
  {% assign sub_items_count = item.children_in_list | size %}
  {% if sub_items_count > 0 %}
    {% assign has_nested_sections = true %}
  {% endif %}
{% endfor %}

{% if show_header %}
  <section class="py-2">
    <div class="mb-4 border-b border-base-300 pb-4">
      <h3 class="text-lg font-semibold text-base-content md:text-2xl">{{ page.settings.title | default: page.link_text }}</h3>
      {% if page.settings.description != blank %}
        <p class="text-sm text-base-content/60">{{ page.settings.description }}</p>
      {% endif %}
    </div>
  </section>
{% endif %}

{% if has_nested_sections %}
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8">
    {% for item in pages %}
      {% assign sub_items_count = item.children_in_list | size %}
      {% if sub_items_count > 0 %}
        <div>
          <h3 class="border-b border-primary pb-2 text-2xl font-semibold text-base-content">
            {{ item.settings.title | default: item.link_text }}
          </h3>
          <div class="mt-4 space-y-2">
            {% for item2 in item.children_in_list %}
              {% if item2.template_name == 'video' %}
                {% render 'content_video_card', item: item2, video_type: video_type %}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% else %}
        <div>
          {% if item.template_name == 'video' %}
            {% render 'content_video_card', item: item, video_type: video_type %}
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
{% else %}
  {% paginate_tag pages, per: 12 %}
    <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3 md:gap-8">
      {% for item in pages %}
        {% if item.template_name == 'video' %}
          {% render 'content_video_card', item: item, video_type: video_type %}
        {% endif %}
      {% endfor %}
    </div>
    <div class="mt-12 block w-full text-right">
      {% render 'paginate', paginate: paginate %}
    </div>
  {% endpaginate_tag %}
{% endif %}
