{% if paginate.total_count > 0 %}
  <div class="flex items-center justify-between px-2 py-3">
    {% if paginate.total_pages > 1 %}

      <div class="flex justify-between flex-1 sm:hidden">
        <a {% if paginate.prev_page %}href="{{ paginate.url_for[paginate.prev_page] }}"{% else %}disabled{% endif %} class="relative inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-base-content bg-base-100 border border-base-300 rounded-lg hover:bg-base-200">
          <i data-lucide="chevron-left" class="h-4 w-4"></i>
          <span>Previous</span>
        </a>
        <a {% if paginate.next_page %}href="{{ paginate.url_for[paginate.next_page] }}"{% else %}disabled{% endif %} class="relative inline-flex items-center gap-2 px-4 py-2 ml-3 text-sm font-medium text-base-content bg-base-100 border border-base-300 rounded-lg hover:bg-base-200">
          <span>Next</span>
          <i data-lucide="chevron-right" class="h-4 w-4"></i>
        </a>
      </div>
      <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
        <div>
          <nav class="inline-flex -space-x-px rounded-lg shadow-sm isolate" aria-label="Pagination">
            {% comment %} 上一页 {% endcomment %}
            <a {% if paginate.prev_page %}href="{{ paginate.url_for[paginate.prev_page] }}"{% else %}disabled{% endif %} class="relative inline-flex items-center px-2 py-2 text-base-content/60 rounded-l-lg ring-1 ring-inset ring-base-300 hover:bg-base-200 focus:z-20 focus:outline-offset-0">
              <span class="sr-only">Previous</span>
              <i data-lucide="chevron-left" class="h-5 w-5" aria-hidden="true"></i>
            </a>

            {% comment %} 页码 {% endcomment %}
            {% for i in paginate.series %}
              {% assign type = i | typeof %}
              {% case type %}
                {% when 'string' %}
                  {% if i == 'gap' %}
                    <span class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-base-content/70 ring-1 ring-inset ring-base-300 focus:outline-offset-0">...</span>
                  {% else %}
                    <a href="#" aria-current="page" class="relative z-10 inline-flex items-center px-4 py-2 text-sm font-semibold text-primary-content bg-primary focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">{{i}}</a>
                  {% endif %}
                {% when 'integer' %}
                  <a href="{{paginate.url_for[i]}}" class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-base-content ring-1 ring-inset ring-base-300 hover:bg-base-200 focus:z-20 focus:outline-offset-0">{{i}}</a>
              {% endcase %}
            {% endfor %}

            {% comment %} 下一页 {% endcomment %}
            <a {% if paginate.next_page %}href="{{ paginate.url_for[paginate.next_page] }}"{% else %}disabled{% endif %} class="relative inline-flex items-center px-2 py-2 text-base-content/60 rounded-r-lg ring-1 ring-inset ring-base-300 hover:bg-base-200 focus:z-20 focus:outline-offset-0">
              <span class="sr-only">Next</span>
              <i data-lucide="chevron-right" class="h-5 w-5" aria-hidden="true"></i>
            </a>
          </nav>
        </div>
      </div>

    {% endif %}
  </div>
{% endif %}
