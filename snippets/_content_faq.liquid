{% if open == 'open' %}
    <div class="ProseMirror mt-2 max-w-full overflow-x-auto border border-base-300 p-2 text-base-content/80 md:p-4">
        {{ item.settings.content }}
    </div>
{% else %}
    <details class="group py-2">
        <summary class="cursor-pointer list-none px-2 py-1 font-semibold text-base-content marker:hidden hover:bg-base-200/50 hover:text-primary [&::-webkit-details-marker]:hidden">
            <span class="inline-flex items-start gap-2">
                <i data-lucide="chevron-right" class="mt-0.5 h-4 w-4 shrink-0 text-base-content transition group-open:rotate-90"></i>
                <span>{{ item.settings.title | default: item.link_text }}</span>
            </span>
        </summary>
        <div class="ProseMirror mt-2 max-w-full overflow-x-auto rounded-box border border-base-300 p-2 text-base-content/80 md:p-4">
            {{ item.settings.content }}
        </div>
    </details>
{% endif %}
