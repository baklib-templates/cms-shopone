{% comment %}
  @params breadcrumb
    array of objects with keys:
      link_text: string
      path: string
{% endcomment %}
<ul class="list-none text-base-content/60 text-xs flex items-center space-x-1 overflow-x-hidden">
  {% for crumb in breadcrumb %}
      <li>
        <div class="flex items-center">
          {% if forloop.index0 > 0 %}
          <i data-lucide="chevron-right" class="h-4 w-4 flex-shrink-0 text-base-content/40" aria-hidden="true"></i>
          {% endif %}
          <a href="{{ crumb.path }}" data-turbo-frame="_top" class="truncate">{{ crumb.link_text }}</a>
        </div>
      </li>
  {% endfor %}
</ul>
