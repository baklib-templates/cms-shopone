  {
    "name": "主题默认值设置",
    "settings": [
      {
        "id": "logo_url",
        "type": "image_picker",
        "ratio": "6:2",
        "width": 200,
        "label": "站点Logo",
        "info": "放在站点顶部导航栏位置"
      },
      {
        "id": "request_form_url",
        "type": "text",
        "label": "Request Form URL",
        "info": "HTTPS URL only. When set, article pages show a Submit a request link below feedback."
      },
      {
        "id": "robot_name",
        "type": "text",
        "label": "AI Assistant name",
        "default": "AI Assistant",
        "info": "Shown in the AI Search panel header."
      },
      {
        "id": "ai_search_completed_text",
        "type": "text",
        "label": "AI completed text",
        "default": "Done.",
        "info": "Displayed after AI Search returns an answer."
      }
    ]
  },
  {
    "name": "首页FAQs版块(FAQs)",
    "settings": [
      {
        "id": "section_faqs_on",
        "type": "checkbox",
        "label": "是否显示FAQs版块",
        "info": "如果选中，则在首页显示FAQs版块；否则不显示",
        "default": true
      },
      {
        "id": "section_faqs_title",
        "type": "text",
        "label": "版块名称",
        "default": "Browse by FAQs"
      },
      {
        "id": "section_faqs_menu",
        "type": "textarea",
        "label": "FAQs导航设置",
        "rows": 10,
        "info": "格式：name[slug[description，每行一个分栏。",
        "default": "Downloads[/downloads{Catalog1[/|Catalog2[/\nVideos[/videos{Catalog1[/|Catalog2[/\nProducts[/products{Catalog1[/|Catalog2[/\nFAQs[/faqs{Catalog1[/|Catalog2[/\nSitemap[/s/sitemap{Catalog1[/|Catalog2[/\n"
      }
    ]
  },
  {
    "name": "首页产品版块(Products)",
    "settings": [
      {
        "id": "section_products_on",
        "type": "checkbox",
        "label": "是否显示Products版块",
        "info": "如果选中，则在首页显示Products版块；否则不显示",
        "default": true
      },
      {
        "id": "section_product_type",
        "type": "checkbox",
        "label": "产品列表按分类显示",
        "info": "如果选中，则在首页产品列表按分类显示；否则显示所有",
        "default": false
      },
      {
        "id": "section_product_title",
        "type": "text",
        "label": "版块名称",
        "default": "Browse by Product"
      },
      {
        "id": "product_categories",
        "type": "text",
        "label": "产品大分类设置",
        "info": "格式：电子产品|医疗器械|工业设备|厨房电器；同时在[标签管理]中添加对应的标签。",
        "default": "Eyes|Lips|Face & Body|Sets & Kits|Pencils|Brushes|Accessories & Tools"
      }
    ]
  },
  {
    "name": "首页话题版块(Topics)",
    "settings": [
      {
        "id": "section_topics_on",
        "type": "checkbox",
        "label": "是否显示Topics版块",
        "info": "如果选中，则在首页显示Topics版块；否则不显示",
        "default": true
      },
      {
        "id": "section_topic_title",
        "type": "text",
        "label": "版块名称",
        "default": "Browse by Topic"
      },
      {
        "id": "topics_menu",
        "type": "textarea",
        "label": "首页话题导航设置",
        "rows": 10,
        "info": "格式：name[slug[description，每行一个分栏。",
        "default": "FAQs[/faqs[some Q&A for all products\nVideos[/videos[the how-to video manuals\nDownloads[/downloads[product downloads and updates"
      }
    ]
  },
  {
    "name": "首页下载版块(Downloads)",
    "settings": [
      {
        "id": "section_downloads_on",
        "type": "checkbox",
        "label": "是否显示Downloads版块",
        "info": "如果选中，则在首页显示Downloads版块；否则不显示",
        "default": true
      },
      {
        "id": "section_downloads_title",
        "type": "text",
        "label": "版块名称",
        "default": "Browse by Downloads"
      },
      {
        "id": "section_downloads_description",
        "type": "text",
        "label": "Section description",
        "default": "Latest product launches, partnerships, and channel updates."
      },
      {
        "id": "section_downloads_slug",
        "type": "text",
        "label": "Downloads channel path",
        "default": "/downloads",
        "info": "Path of the channel whose list-visible child pages appear as homepage download cards (e.g. /downloads)."
      }
    ]
  },
  {
    "name": "首页联系版块(Contact US)",
    "settings": [
      {
        "id": "section_contact_on",
        "type": "checkbox",
        "label": "是否显示Contact版块",
        "info": "如果选中，则在首页显示Contact版块；否则不显示",
        "default": true
      },
      {
        "id": "section_contact_title",
        "type": "text",
        "label": "版块名称",
        "default": "Contact Us"
      },
      {
        "id": "email",
        "type": "text",
        "label": "Email",
        "default": "some@example.com"
      },
      {
        "id": "phone",
        "type": "text",
        "label": "Phone",
        "default": "1234567890"
      },
      {
        "id": "phone_name",
        "type": "text",
        "label": "Phone Name",
        "default": "Monday-Friday, 10:00 AM - 6:00 PM EST"
      },
      {
        "id": "chat_url",
        "type": "text",
        "label": "Chat 链接",
        "default": "#"
      },
      {
        "id": "chat_name",
        "type": "text",
        "label": "Chat Name",
        "default": "@google"
      },
      {
        "id": "contact_url",
        "type": "text",
        "label": "Contact Form 链接",
        "default": "#"
      },
      {
        "id": "contact_name",
        "type": "text",
        "label": "Contact Name",
        "default": ""
      }
    ]
  },
  {
    "name": "页头页脚菜单设计",
    "settings": [
      {
        "id": "header_menu",
        "type": "textarea",
        "label": "页头导航菜单设置",
        "rows": 10,
        "info": "格式：menu_name[slug]{sub_menu[slug|sub_menu[slug，每行一个分栏。",
        "default": "Home[/\nDownloads[/downloads\nVideos[/videos\nProducts[/products{Catalog1[/products/pro1|Catalog2[/products/pro2\nFAQs[/faqs\nSitemap[/s/sitemap"
      },
      {
        "id": "footer_menu",
        "type": "textarea",
        "label": "页脚菜单设置",
        "rows": 10,
        "info": "格式：menu_name[slug]{sub_menu[slug|sub_menu[slug，每行一个分栏。",
        "default": "Products[/products{Catalog1[/products/pro1|Catalog2[/products/pro2\nVideos[/videos\nDownloads[/downloads"
      },
      {
        "id": "company_info",
        "type": "text",
        "label": "页脚版权公司信息",
        "default": "&copy; 2025 Google Inc. All Rights Reserved."
      },
      {
        "id": "friend_links",
        "type": "html",
        "label": "页脚社交媒体",
        "rows": 10,
        "info": "格式：<a href=''>svg icon</a>; ICON图标下载地址： https://www.bootstrapmb.com/icon"
      },
      {
        "id": "font_html",
        "type": "html",
        "label": "自定义字体",
        "info": "请按照默认值格式替换字体名称和字体路径，注意必须用.font-custom类定义字体",
        "rows": 10,
        "default": "<style>\n  @font-face {\n    font-family: 'Helvetica Now Display';\n    font-style: normal;\n    font-weight: normal;\n    font-display: swap;\n    src: url('{{ 'images/font/HelveticaNowDisplay-Bold.otf' | asset_url }}') format('otf'),url('{{ 'images/font/HelveticaNowDisplay-Medium.otf' | asset_url }}') format('otf'),url('{{ 'images/font/HelveticaNowDisplay-Regular.otf' | asset_url }}') format('otf');\n  }\n  .font-custom {\n      font-family: 'Helvetica Now Display';\n    }\n</style>\n"
      },
      {
        "id": "head_html",
        "type": "html",
        "label": "<head>标签内 HTML 代码",
        "rows": 10
      }
    ]
  }
]
